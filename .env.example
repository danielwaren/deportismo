# =============================================================================
# Frontend (Astro) — SOLO claves públicas. Estas SÍ llegan al navegador.
# =============================================================================
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="ey..."   # anon/publishable key (segura para el cliente)

# =============================================================================
# Edge Functions (Supabase) — NUNCA van en el frontend ni en este repo en claro.
# Se configuran como SECRETS en Supabase:
#   supabase secrets set API_FOOTBALL_KEY=xxxx
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=xxxx   (lo provee Supabase)
# Se listan aquí solo como documentación de qué necesita el backend.
# =============================================================================
# API_FOOTBALL_KEY="..."                 # clave de api-football.com — SOLO backend
# API_FOOTBALL_HOST="v3.football.api-sports.io"
# SUPABASE_SERVICE_ROLE_KEY="..."        # service role — SOLO backend
# DAILY_REQUEST_BUDGET="100"             # cuota dura del plan free
