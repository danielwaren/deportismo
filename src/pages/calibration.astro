---
import Base from '../layouts/Base.astro';
import CalibrationPanel from '../components/CalibrationPanel.tsx';
---

<Base title="Calibración · STI">
  <h1 class="text-xl font-semibold">Calibración del modelo</h1>
  <p class="mb-4 mt-1 text-sm text-terminal-muted">
    ¿Las probabilidades del modelo se cumplen en la realidad? Brier score, log-loss
    y reliability diagram desde la vista <code class="font-mono">prediction_calibration</code>.
  </p>
  <CalibrationPanel client:load />
</Base>
