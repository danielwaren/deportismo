---
import Base from '../layouts/Base.astro';
import QuotaMeter from '../components/QuotaMeter.tsx';
import AdminWeights from '../components/AdminWeights.tsx';
---

<Base title="Admin · STI">
  <h1 class="text-xl font-semibold">Panel de administración</h1>
  <p class="mb-4 mt-1 text-sm text-terminal-muted">
    Ajusta los pesos del ensemble y vigila el consumo de cuota. La edición persiste
    solo con Supabase y un usuario con rol <code class="font-mono">admin</code> (RLS).
  </p>

  <div class="grid gap-4 lg:grid-cols-2">
    <AdminWeights client:load />
    <QuotaMeter client:load />
  </div>
</Base>
