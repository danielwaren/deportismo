---
import Base from '../layouts/Base.astro';
import TodayBoard from '../components/TodayBoard.tsx';
import MatchBoard from '../components/MatchBoard.tsx';
---

<Base title="Dashboard · STI">
  <section class="mb-6">
    <h1 class="text-xl font-semibold">Dashboard</h1>
    <p class="mt-1 text-sm text-terminal-muted">
      Pronósticos del día y buscador. Entra a un partido para ver el modelo
      completo: 1X2, marcadores, Monte Carlo, valor, explicación y laboratorio.
    </p>
  </section>

  <!-- Partidos del día / próximos + destacados -->
  <TodayBoard client:load />

  <!-- Buscador por equipo -->
  <div class="mt-8">
    <MatchBoard client:load />
  </div>
</Base>
